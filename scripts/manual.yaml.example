# scripts/manual.yaml.example
#
# Copy this to ~/Claude Folder/personal/Finance/manual.yaml and fill in.
# The sync script reads this for things that don't extract well from PDFs/images
# (RRSP/TFSA splits, real estate values, ticker metadata, entity mappings).
#
# Crypto balances and bank balances are auto-extracted from your finance files
# and override values in `holdingsScaffold` below.

# ── Bank account mapping ───────────────────────────────────────────────────
# Maps "<bank> <last4>" or "<holder> <bank>" → cash account name in holdings.
# Add entries for accounts the script can't auto-match by bank+holder.
bankAccountMap:
  # Examples (adjust to your accounts):
  "BMO 9037": "Vegrow BMO"
  "BMO 2252": "Blockwiz BMO"
  "BMO 8114": "Seglitix BMO"
  "Scotia 6786": "Dev Scotia"
  "Scotia 6522": "Shalini Scotia"
  # Wise often doesn't show last 4 digits — use holder instead
  "BlockWiz Solutions Limited Wise": "Blockwiz Wise"
  # If only one account at a bank, holder match alone works
  "Blockwiz Scotia": "Blockwiz Scotia"

# ── holdingsScaffold ───────────────────────────────────────────────────────
# This is the canonical structure of data/holdings.json. The sync script
# clones this, then overrides:
#   - owners.Dev.crypto.{Ledger,Coinbase} from CSVs
#   - owners.<X>.cash.<account> balances from extracted bank records
#
# Update `accountSplits` below when you change RRSP/TFSA/Cash share quantities.
# Update `realEstate` when property values change.
holdingsScaffold:
  lastUpdated: "2026-04-30"
  notes: "Filled in by sync-holdings.mjs"
  owners:
    Dev:
      questrade:
        RRSP:
          GOOG: 61.64
          META: 5
          MSFT: 8
          NFLX: 110
          TSLA: 37
        TFSA:
          VFV.TO: 213
          ZID.TO: 271
        Cash:
          VFV.TO: 2034
          MSFT: 52.03
      crypto:
        # Ledger and Coinbase auto-filled by sync script
        Binance:
          BNB: 22.63
          TRX: 35865
      cash:
        "USDC (Ledger)": 48994.46
        "USDT (Ledger)": 55.73
        Questrade: 396
        "Dev Scotia": 15675
        "Blockwiz Scotia": 28981
        "Blockwiz Wise": 5508
        "Seglitix BMO": 13772
        "Blockwiz BMO": 2474
    Shalini:
      questrade:
        RRSP:
          GOOG: 37.5
          MSFT: 15
          TSLA: 63
        TFSA:
          VFV.TO: 293
          ZID.TO: 16
        Cash:
          VFV.TO: 576
          ZID.TO: 399
      crypto: {}
      cash:
        Questrade: 568
        "Shalini Scotia": 5305
    Vegrow:
      questrade:
        Cash:
          ZID.TO: 1119
          CASH.TO: 499
          VFV.TO: 134
      crypto: {}
      cash:
        Questrade: 188.68
        "Vegrow BMO": 13581

  tickerMeta:
    GOOG:    { name: "Alphabet Inc",                     currency: "USD", yahoo: "GOOG" }
    META:    { name: "Meta Platforms",                   currency: "USD", yahoo: "META" }
    MSFT:    { name: "Microsoft Corp",                   currency: "USD", yahoo: "MSFT" }
    NFLX:    { name: "Netflix Inc",                      currency: "USD", yahoo: "NFLX" }
    TSLA:    { name: "Tesla Inc",                        currency: "USD", yahoo: "TSLA" }
    VFV.TO:  { name: "Vanguard S&P 500 ETF",             currency: "CAD", yahoo: "VFV.TO" }
    ZID.TO:  { name: "BMO MSCI India ETF",               currency: "CAD", yahoo: "ZID.TO" }
    CASH.TO: { name: "Global X High Interest Savings ETF", currency: "CAD", yahoo: "CASH.TO" }
    BTC:     { name: "Bitcoin",                          currency: "USD", yahoo: "BTC-USD" }
    ETH:     { name: "Ethereum",                         currency: "USD", yahoo: "ETH-USD" }
    SOL:     { name: "Solana",                           currency: "USD", yahoo: "SOL-USD" }
    XRP:     { name: "XRP",                              currency: "USD", yahoo: "XRP-USD" }
    BNB:     { name: "BNB",                              currency: "USD", yahoo: "BNB-USD" }
    LTC:     { name: "Litecoin",                         currency: "USD", yahoo: "LTC-USD" }
    TRX:     { name: "TRON",                             currency: "USD", yahoo: "TRX-USD" }
    MANA:    { name: "Decentraland",                     currency: "USD", yahoo: "MANA-USD" }
    SAND:    { name: "The Sandbox",                      currency: "USD", yahoo: "SAND-USD" }

  cashCurrencies:
    "USDC (Ledger)": "USD"
    "USDT (Ledger)": "USD"
    Questrade: "CAD"
    "Dev Scotia": "CAD"
    "Shalini Scotia": "CAD"
    "Blockwiz Scotia": "CAD"
    "Blockwiz Wise": "CAD"
    "Seglitix BMO": "CAD"
    "Blockwiz BMO": "CAD"
    "Vegrow BMO": "CAD"

  realEstate:
    "Ireo Grand Arch":
      value: 53500000
      currency: "INR"
      country: "India"
      owners: ["Dev", "Shalini"]
    "Garvin Mews":
      value: 1100000
      currency: "CAD"
      country: "Canada"
      owners: ["Dev", "Shalini"]

  entityMapping:
    "Blockwiz Wise": "Blockwiz"
    "Blockwiz Scotia": "Blockwiz"
    "Blockwiz BMO": "Blockwiz"
    "Seglitix BMO": "Seglitix"
    "Vegrow BMO": "Vegrow"
    "Dev Scotia": "Dev"
    "Shalini Scotia": "Shalini"
    Questrade: "same"

  cryptoEntityMapping:
    Ledger: ["Dev"]
    Coinbase: ["Dev"]
    Binance: ["Dev"]

  countryMapping:
    ZID.TO: "India"
    GOOG: "USA"
    META: "USA"
    MSFT: "USA"
    NFLX: "USA"
    TSLA: "USA"
    VFV.TO: "USA"
    CASH.TO: "Canada"
    BTC: "Global"
    ETH: "Global"
    SOL: "Global"
    XRP: "Global"
    BNB: "Global"
    LTC: "Global"
    TRX: "Global"
    MANA: "Global"
    SAND: "Global"
